#
# https://help.github.com/articles/dealing-with-line-endings/
#
# These are explicitly windows files and should use crlf
*.bat           text eol=crlf

# Planet saves are large binary-like snapshots and should not inflate Git history.
planet/save/*.json filter=lfs diff=lfs merge=lfs -text
planet/save/*.json.gz filter=lfs diff=lfs merge=lfs -text

